{
  "name": "Hyperclaw",
  "version": "0.2.0",
  "description": "Hypercho Hyperclaw - AI-powered desktop application",
  "author": "Hypercho",
  "main": "main.js",
  "scripts": {
    "electron:dev": "electron ."
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^24.13.3",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.hypercho.hyperclaw",
    "productName": "Hyperclaw",
    "asar": true,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "app-config.json",
      "../public/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "../public/win.ico",
      "artifactName": "${productName}-${version}-win.${ext}"
    },
    "mac": {
      "target": ["zip"],
      "icon": "../public/icon.icns",
      "artifactName": "${productName}-${version}-mac.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "../public/icon.png",
      "artifactName": "${productName}-${version}-linux.${ext}"
    },
    "extraResources": [
      {
        "from": "../.next",
        "to": "../.next",
        "filter": ["**/*"]
      }
    ]
  }
}
