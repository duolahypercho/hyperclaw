    "start": "next start -p 1000",
    "lint": "next lint",
    "electron": "cd electron && npm run electron",
    "electron:dev": "cd electron && npm run electron:dev",
    "electron:build": "npm run build && cd electron && npm run electron:build",
    "electron:build:win": "npm run build && cd electron && npm run electron:build:win",
    "electron:build:win:local": "npm run build && cd electron && npm run electron:build:win:local",
    "electron:build:win:remote": "cd electron && npm run electron:build:win:remote",
    "electron:build:mac:local": "npm run build && cd electron && npm run electron:build:mac:local",
    "electron:build:mac:remote": "cd electron && npm run electron:build:mac:remote",
    "electron:build:linux:remote": "cd electron && npm run electron:build:linux:remote",
    "electron:build:linux:local": "cd electron && npm run electron:build:linux:local",
    "test": "vitest run",
    "test:watch": "vitest",
    "connector:build": "cd electron && npm run build-connector",
    "connector:build:all": "cd electron && npm run build-connector:all",
    "plugin:pack": "bash scripts/plugin/pack-plugin.sh"
