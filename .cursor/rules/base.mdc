@tailwind base;

@layer base {
  :root {
    /* Neutrals */
    --background: 216 33% 97%; /* very light blue‑white */
    --foreground: 216 5% 15%; /* dark charcoal-blue */
    --card: 0 0% 100%; /* pure white */
    --card-foreground: 216 5% 15%;
    --popover: 0 0% 100%;
    --popover-foreground: 216 5% 15%;

    /* Brand Primary */
    --primary: 216 100% 89%; /* your light‑blue brand */
    --primary-foreground: 216 5% 15%; /* text/icon on primary */

    /* Secondary Palette */
    --secondary: 216 50% 70%; /* mid‑tone blue */
    --secondary-foreground: 216 5% 15%;

    /* Muted / Subtle UI */
    --muted: 216 20% 91%; /* very soft blue tint */
    --muted-foreground: 216 5% 45%; /* medium gray‑blue */

    /* Accent & Feedback */
    --accent: 216 100% 89%; /* same as brand color */
    --accent-foreground: 216 5% 15%; /* text/icon on accent */

    --destructive: 0 84% 60%; /* vivid red for errors */
    --destructive-foreground: 0 0% 98%; /* white text */

    /* Borders, Inputs, Rings */
    --border: 216 20% 85%; /* light border */
    --input: 216 20% 85%;
    --ring: 216 100% 70%; /* soft focus outline */

    /* Radius */
    --radius: 0.75rem;

    /* Chart Colors (optional harmony) */
    --chart-1: 216 100% 60%;
    --chart-2: 216 70% 50%;
    --chart-3: 216 50% 30%;
    --chart-4: 43 74% 66%;
    --chart-5: 27 87% 67%;
  }

  .dark {
    /* Inverted neutrals */
    --background: 216 50% 10%; /* deep midnight blue */
    --foreground: 0 0% 98%; /* white */
    --card: 216 50% 15%; /* dark card surface */
    --card-foreground: 0 0% 98%;
    --popover: 216 50% 15%;
    --popover-foreground: 0 0% 98%;

    /* Primary becomes light on dark */
    --primary: 216 100% 89%; /* your light‑blue brand */
    --primary-foreground: 216 50% 15%; /* text/icon on primary */

    --secondary: 216 30% 30%; /* subtle dark secondary */
    --secondary-foreground: 0 0% 98%; /* white text */

    --muted: 216 30% 30%;
    --muted-foreground: 216 20% 70%;

    --accent: 216 100% 89%; /* same as brand color */
    --accent-foreground: 216 50% 15%; /* text/icon on accent */

    --destructive: 0 62.8% 30.6%; /* dark red for errors */
    --destructive-foreground: 0 0% 98%; /* white text */

    --border: 216 30% 30%;
    --input: 216 30% 30%;
    --ring: 216 100% 70%;

    --chart-1: 216 70% 50%;
    --chart-2: 160 60% 45%;
    --chart-3: 30 80% 55%;
    --chart-4: 280 65% 60%;
    --chart-5: 340 75% 55%;
  }
}

