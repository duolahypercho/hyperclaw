# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:1000
NEXTAUTH_SECRET=          # openssl rand -base64 32
DOMAIN=                   # Production cookie domain (e.g. hypercho.com)

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Twitter / X OAuth ───────────────────────────────────────────────────────
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=http://localhost:1000/api/auth/callback/x

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PLAN_ID=
STRIPE_ANNUAL_PLAN_ID=

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
S3_UPLOAD_KEY=
S3_UPLOAD_SECRET=
S3_UPLOAD_REGION=
S3_UPLOAD_BUCKET=

# ─── Sentry ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=   # From sentry.io → Project Settings → Client Keys (DSN)
SENTRY_ORG=hypercho
SENTRY_PROJECT=hypercho
SENTRY_AUTH_TOKEN=        # From sentry.io → Settings → Auth Tokens (for source maps)

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info            # pino log level: debug, info, warn, error

# ─── Public (exposed to browser) ─────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:1000
NEXT_PUBLIC_CLOUD_FRONT_URL=
NEXT_PUBLIC_HYPERCHO_API=https://api.hypercho.com/
NEXT_PUBLIC_MEDIASERVICE_API=
NEXT_PUBLIC_COPANION_RUNTIME_URL=
NEXT_PUBLIC_HUB_API_URL=https://hub.hypercho.com
NEXT_PUBLIC_HUB_URL=wss://hub.hypercho.com
NEXT_PUBLIC_OPENCLAW_GATEWAY_PORTS=18789
NEXT_PUBLIC_ENV=development
