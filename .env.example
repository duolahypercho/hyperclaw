# =============================================================================
# Hyperclaw — Environment Configuration
# =============================================================================
# Copy this file to `.env.local` (for development) or `.env.production` and
# fill in the values you need.
#
# Two editions of Hyperclaw exist:
#
#   * Community Edition (this repo, MIT licensed)
#       - Local-only by default. The dashboard talks directly to a connector
#         daemon running on the same machine.
#       - You only need NEXTAUTH_SECRET and (optionally) provider credentials
#         for any features you actually use.
#       - Hub-related env vars (NEXT_PUBLIC_HUB_URL, etc.) can be left empty.
#
#   * Hyperclaw Cloud (proprietary, hosted at hypercho.com)
#       - The dashboard connects to a remote hub for multi-device sync,
#         hosted agents, and team workspaces.
#       - Cloud builds set the NEXT_PUBLIC_HUB_* and NEXT_PUBLIC_HYPERCHO_API
#         vars at build time.
#
# Anything left blank in this template is genuinely optional unless the file
# notes otherwise.
# =============================================================================

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Optional for Community/local builds, which can run in guest local mode.
# Required for Cloud/remote builds because NEXTAUTH_SECRET protects session cookies.
NEXTAUTH_URL=http://localhost:1000
NEXTAUTH_SECRET=          # openssl rand -base64 32
DOMAIN=                   # Production cookie domain (e.g. example.com)
# Local credentials are for localhost desktop/dev use. Set true only if you
# intentionally expose the dashboard on a trusted private network.
HYPERCLAW_ALLOW_NETWORK_LOGIN=false

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OpenAI (optional) ───────────────────────────────────────────────────────
# Required only for features that call the OpenAI API directly (e.g. the
# in-app autosuggest / text enhance endpoints). Most AI runtime traffic flows
# through the connector → claude/codex CLI instead.
OPENAI_API_KEY=
# Multi-org accounts only — leave empty if your key has a single default org.
OPENAI_ORG_ID=

# ─── AWS S3 (optional) ───────────────────────────────────────────────────────
# Required for the file/knowledge upload features. Skip if you don't use them.
S3_UPLOAD_KEY=
S3_UPLOAD_SECRET=
S3_UPLOAD_REGION=
S3_UPLOAD_BUCKET=

# ─── Sentry (optional) ───────────────────────────────────────────────────────
# Wire up your own Sentry org/project if you want error reporting.
NEXT_PUBLIC_SENTRY_DSN=   # From sentry.io → Project Settings → Client Keys
SENTRY_ORG=               # e.g. your-org
SENTRY_PROJECT=           # e.g. hyperclaw-fork
SENTRY_AUTH_TOKEN=        # From sentry.io → Settings → Auth Tokens

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info            # pino log level: debug, info, warn, error
# ─── Public (exposed to browser) ─────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:1000
NEXT_PUBLIC_CLOUD_FRONT_URL=

# Build flavor. Community/local builds must not contact Hyperclaw Cloud by
# default. Cloud builds set BUILD_FLAVOR=cloud plus HYPERCLAW_REMOTE_URL.
BUILD_FLAVOR=community
HYPERCLAW_BUILD_FLAVOR=community
HYPERCLAW_REMOTE_URL=

# Hyperclaw Cloud backend URL. Leave empty for Community Edition.
NEXT_PUBLIC_HYPERCHO_API=

# Optional media-service URL. Leave empty if you aren't running one.
NEXT_PUBLIC_MEDIASERVICE_API=
NEXT_PUBLIC_COPANION_RUNTIME_URL=

# Hub URLs. Leave empty for Community Edition (local-only mode).
# Set both for Cloud builds, e.g.:
#   NEXT_PUBLIC_HUB_API_URL=https://hub.example.com
#   NEXT_PUBLIC_HUB_URL=wss://hub.example.com
NEXT_PUBLIC_HUB_API_URL=
NEXT_PUBLIC_HUB_URL=
# Localhost/Electron dashboards are local-only by default. Set this to true
# only when intentionally testing the remote hub relay from a local dev URL.
NEXT_PUBLIC_ALLOW_HUB_FALLBACK=false
# Development-only override that forces the dashboard to prefer the local
# connector even when the browser URL is not localhost.
NEXT_PUBLIC_LOCAL_BRIDGE=false

NEXT_PUBLIC_OPENCLAW_GATEWAY_PORTS=18789
NEXT_PUBLIC_ENV=development

# Connector binary filenames (only used by the desktop downloader UI).
NEXT_PUBLIC_MACOS_ARM64_FILE_NAME=OpenClaw-arm64.dmg
NEXT_PUBLIC_MACOS_INTEL_FILE_NAME=OpenClaw-x64.dmg
NEXT_PUBLIC_WINDOWS_FILE_NAME=OpenClaw-Setup.exe

# Connector releases URL. Leave empty for Community Edition — the dashboard
# instead tells users to build the bundled `./connector` locally. Cloud builds
# point this at e.g. https://github.com/your-org/your-connector/releases.
NEXT_PUBLIC_CONNECTOR_RELEASES_URL=
