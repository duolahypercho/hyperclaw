# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.prettierrc
.prettierignore

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env

# electron build artifacts
electron/dist-electron/
electron/build/
electron/node_modules/
electron/*.exe
electron/*.blockmap
electron/*.dmg
electron/*.AppImage
electron/*.deb
electron/*.rpm

# plugin tarball (auto-built by prebuild script)
public/hyperclaw-plugin.tgz

# extension subdirectory node_modules and build artifacts
extensions/*/node_modules/
extensions/*/dist/

.gstack/
